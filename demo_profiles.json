{
  "description": "Ready-to-use demo profiles for the IncomeIQ prediction API. All categorical fields use sklearn alphabetical LabelEncoder values matching income_cleandata.csv.",
  "encoding_reference": {
    "workclass":      {"0":"Federal-gov","1":"Local-gov","2":"Never-worked","3":"Private","4":"Self-emp-inc","5":"Self-emp-not-inc","6":"State-gov","7":"Without-pay"},
    "education_num":  {"1":"Preschool","9":"HS-grad","10":"Some-college","12":"Assoc-acdm","13":"Bachelors","14":"Masters","16":"Doctorate"},
    "marital_status": {"0":"Divorced","1":"Married-AF-spouse","2":"Married-civ-spouse","3":"Married-spouse-absent","4":"Never-married","5":"Separated","6":"Widowed"},
    "occupation":     {"0":"Adm-clerical","3":"Exec-managerial","7":"Other-service","9":"Prof-specialty","11":"Sales","12":"Tech-support"},
    "relationship":   {"0":"Husband","1":"Not-in-family","2":"Other-relative","3":"Own-child","4":"Unmarried","5":"Wife"},
    "race":           {"0":"Amer-Indian-Eskimo","1":"Asian-Pac-Islander","2":"Black","3":"Other","4":"White"},
    "sex":            {"0":"Female","1":"Male"},
    "native_country": {"38":"United-States","39":"Vietnam","18":"India","25":"Mexico"}
  },
  "profiles": [
    {
      "name": "Corporate Executive",
      "description": "Senior private-sector manager with Masters degree. High capital gains, long hours. Expected: >50K",
      "expected_income": ">50K",
      "payload": {
        "age": 45,
        "workclass": 3,
        "education_num": 14,
        "marital_status": 2,
        "occupation": 3,
        "relationship": 0,
        "race": 4,
        "sex": 1,
        "capital_gain": 15024,
        "capital_loss": 0,
        "hours_per_week": 50,
        "native_country": 38
      },
      "curl_example": "curl -X POST http://localhost:5000/predict -H 'Content-Type: application/json' -d '{\"age\":45,\"workclass\":3,\"education_num\":14,\"marital_status\":2,\"occupation\":3,\"relationship\":0,\"race\":4,\"sex\":1,\"capital_gain\":15024,\"capital_loss\":0,\"hours_per_week\":50,\"native_country\":38}'"
    },
    {
      "name": "Government Clerk",
      "description": "State government administrative worker, Bachelors degree, single. Modest capital gains, standard hours. Expected: <=50K",
      "expected_income": "<=50K",
      "payload": {
        "age": 39,
        "workclass": 6,
        "education_num": 13,
        "marital_status": 4,
        "occupation": 0,
        "relationship": 1,
        "race": 4,
        "sex": 1,
        "capital_gain": 2174,
        "capital_loss": 0,
        "hours_per_week": 40,
        "native_country": 38
      },
      "curl_example": "curl -X POST http://localhost:5000/predict -H 'Content-Type: application/json' -d '{\"age\":39,\"workclass\":6,\"education_num\":13,\"marital_status\":4,\"occupation\":0,\"relationship\":1,\"race\":4,\"sex\":1,\"capital_gain\":2174,\"capital_loss\":0,\"hours_per_week\":40,\"native_country\":38}'"
    },
    {
      "name": "Early Career Worker",
      "description": "Young part-time service worker with some college education, single. No capital gains. Expected: <=50K",
      "expected_income": "<=50K",
      "payload": {
        "age": 24,
        "workclass": 3,
        "education_num": 10,
        "marital_status": 4,
        "occupation": 7,
        "relationship": 3,
        "race": 4,
        "sex": 0,
        "capital_gain": 0,
        "capital_loss": 0,
        "hours_per_week": 30,
        "native_country": 38
      },
      "curl_example": "curl -X POST http://localhost:5000/predict -H 'Content-Type: application/json' -d '{\"age\":24,\"workclass\":3,\"education_num\":10,\"marital_status\":4,\"occupation\":7,\"relationship\":3,\"race\":4,\"sex\":0,\"capital_gain\":0,\"capital_loss\":0,\"hours_per_week\":30,\"native_country\":38}'"
    }
  ],
  "how_to_run": {
    "step1": "pip install -r requirements.txt && pip install -e .",
    "step2": "Place income_cleandata.csv in data-source/",
    "step3": "python main.py   # trains model, saves artifacts",
    "step4": "python app.py    # starts Flask on http://localhost:5000",
    "step5": "python test-request.py   # or open http://localhost:5000 in browser"
  }
}
